{
  "name": "giveready",
  "version": "0.1.0",
  "description": "Making small nonprofits discoverable and donatable through AI",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create giveready-db",
    "db:migrate": "wrangler d1 execute giveready-db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute giveready-db --local --file=./schema.sql",
    "db:seed": "wrangler d1 execute giveready-db --file=./seed.sql",
    "db:seed:local": "wrangler d1 execute giveready-db --local --file=./seed.sql"
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "ed25519-hd-key": "^1.3.0"
  }
}
