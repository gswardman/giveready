{
  "name": "giveready",
  "version": "0.1.0",
  "description": "Making small nonprofits discoverable and donatable through AI",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "node --test tests/",
    "test:auth": "node --test tests/auth-unit.test.js",
    "db:create": "wrangler d1 create giveready-db",
    "db:migrate": "wrangler d1 execute giveready-db --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute giveready-db --local --file=./schema.sql",
    "db:migrate:011": "wrangler d1 execute giveready-db --remote --file=./migrations/011-charity-dashboard.sql",
    "db:migrate:011:local": "wrangler d1 execute giveready-db --local --file=./migrations/011-charity-dashboard.sql",
    "db:seed": "wrangler d1 execute giveready-db --file=./seed.sql",
    "db:seed:local": "wrangler d1 execute giveready-db --local --file=./seed.sql",
    "db:seed:cks": "wrangler d1 execute giveready-db --remote --file=./scripts/seed-cks-demo.sql",
    "db:seed:cks:local": "wrangler d1 execute giveready-db --local --file=./scripts/seed-cks-demo.sql"
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bip39": "^3.1.0",
    "bs58": "^6.0.0",
    "ed25519-hd-key": "^1.3.0"
  }
}
